# Redis connection string (e.g., redis://localhost:6379)
REDIS_URL=

# How many jobs a worker processes at once by default
QUEUE_DEFAULT_CONCURRENCY=1

# How often the worker checks in to say it's alive (milliseconds)
HEARTBEAT_INTERVAL_MS=5000

# How long a job can go without a heartbeat before being considered "stalled" (milliseconds)
STALL_THRESHOLD_MS=30000

# How often the scheduler checks for delayed jobs (milliseconds)
SCHEDULER_POLL_MS=500
